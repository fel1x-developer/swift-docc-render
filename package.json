{
  "name": "swift-docc-render",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "test": "npm run test:unit && npm run lint && npm run test:license",
    "test:license": "./bin/check-source",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint ./src --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "lint:fix": "eslint ./src --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "docs": "bin/build-and-serve-docs",
    "docs:preview": "bin/build-and-serve-docs",
    "docs:build": "bin/build-docs",
    "docs:serve": "bin/serve-docs"
  },
  "dependencies": {
    "@unhead/vue": "^1.11.7",
    "@vue/eslint-config-airbnb-with-typescript": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "css.escape": "^1.5.1",
    "ejs": "^3.1.10",
    "highlight.js": "^11.10.0",
    "intersection-observer": "^0.12.2",
    "portal-vue": "^3.0.0",
    "vite-plugin-ejs": "^1.7.0",
    "vue": "^3.4.29",
    "vue-i18n": "^9.14.1",
    "vue-router": "^4.4.5",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@fel1x-developer/tree-sitter-vue": "^0.3.0",
    "@rushstack/eslint-patch": "^1.10.4",
    "@tsconfig/node20": "^20.1.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.16.10",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vitest-globals": "^1.5.0",
    "eslint-plugin-vue": "^9.28.0",
    "eslint-plugin-vuejs-accessibility": "^2.4.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "sass-embedded": "^1.79.4",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-jsdoc": "^0.23.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-banner": "^0.8.0",
    "vite-plugin-node-polyfills": "^0.22.0",
    "vitest": "^2.1.1",
    "vue-tsc": "^2.1.6"
  }
}
